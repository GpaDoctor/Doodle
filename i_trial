import Foundation

class Task {
    var title: String
    var description: String
    var category: String
    var dueDate: Date?

    init(_ title: String, _ description: String, _ category: String, _ dueDate: Date?) {
        self.title = title
        self.description = description
        self.category = category
        self.dueDate = dueDate
    }

    func toString() -> String {
        let df = DateFormatter()
        df.dateFormat = "dd-MMM-yyyy"
        let dueDateString = dueDate != nil ? df.string(from: dueDate!) : "no due date"
        return "[\(title)|\(description)|\(category)|\(dueDateString)]"
    }
}

