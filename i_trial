import Foundation

class Task {
    var title: String
    var description: String
    var category: String
    var dueDate: Date?

    init(title: String, description: String, category: String, dueDate: Date? = nil) {
        self.title = title
        self.description = description
        self.category = category
        self.dueDate = dueDate
    }

    func toString() -> String {
        var taskString = "Title: \(title)\nDescription: \(description)\nCategory: \(category)"
        if let dueDate = dueDate {
            let dateFormatter = DateFormatter()
            dateFormatter.dateStyle = .short
            dateFormatter.timeStyle = .short
            taskString += "\nDue Date: \(dateFormatter.string(from: dueDate))"
        }
        return taskString
    }
}

